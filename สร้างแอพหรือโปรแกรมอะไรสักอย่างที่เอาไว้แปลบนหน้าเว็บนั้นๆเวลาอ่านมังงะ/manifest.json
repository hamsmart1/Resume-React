{
  "manifest_version": 3,
  "name": "Manga Web Translator",
  "version": "1.0",
  "description": "Translate manga pages directly on your browser by drag-selecting text areas.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "tesseract.min.js",
        "worker.min.js",
        "tesseract-core.wasm",
        "tesseract-core-simd.wasm"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}